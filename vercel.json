{
  "buildCommand": "npx expo export --platform web && node scripts/postbuild-web.js",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" },
    {
      "source": "/app/((?!_expo/|assets/|favicon\\.ico|metadata\\.json).*)",
      "destination": "/app/index.html"
    }
  ]
}
